# --- Necesse game server config (staged/applied by the control sidecar) ---
WORLD=world
SLOTS=10
OWNER=
MOTD=This server is made possible by Docker!
PASSWORD=
PAUSE=0
GIVE_CLIENTS_POWER=1
LOGGING=1
ZIP=1
HOST_PORT=14159

# --- UI app config ---
# Generate with: node ui/server/scripts/hash-password.js <your-password>
# IMPORTANT: docker compose interpolates ${VAR} from this file into
# docker-compose.yaml, and its own $ escaping applies to *values* too -- a
# bcrypt hash contains literal $ characters, so double every $ as $$ here
# (e.g. $2a$12$abc... becomes $$2a$$12$$abc...) or the hash will be silently
# corrupted when the ui container starts and login will always fail.
UI_PASSWORD_HASH=
SESSION_SECRET=
UI_PORT=3000

# Set to 1 only when the ui service is actually running behind a reverse proxy
# (e.g. cloudflared) that terminates TLS and sets X-Forwarded-* headers.
TRUST_PROXY=0
